    "scripts": {
        "dev": "pnpm run orval && next dev -p 3002 -H 0.0.0.0 | pino-pretty --messageKey=message",
        "dev-no-orval": "next dev -p 3002 -H 0.0.0.0 | pino-pretty --messageKey=message",
        "build": "next build",
        "build:e2e": "NEXT_PUBLIC_ASSET_PREFIX= NEXT_PUBLIC_RUNTIME_ENVIRONMENT=e2e pnpm build && cp -R .next/static .next/standalone/.next",
        "start": "next start",
        "test": "vitest",
        "lintStaged": "lint-staged",
        "lint": "eslint",
        "fetch-api-docs": "curl -o ./innsyn-api.json https://digisos.ekstern.dev.nav.no/sosialhjelp/innsyn-api/v3/api-docs && prettier --write innsyn-api.json",
        "fetch-api-docs-local": "curl -o ./innsyn-api.json  http://localhost:8080/sosialhjelp/innsyn-api/v3/api-docs  && prettier --write innsyn-api.json",
        "orval": "rm -rf src/generated && orval",
        "prettier": "prettier --write src/**/*.{ts,tsx,css,js}",
        "tsc": "tsc",
        "prepare": "husky",
        "e2e": "playwright test",
        "e2e:ui": "playwright test --ui",
        "preinstall": "pnpm dlx only-allow pnpm",
        "knip": "knip"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.3",
        "@faker-js/faker": "^10.4.0",
        "@playwright/test": "^1.59.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/js-cookie": "^3.0.6",
        "@types/node": "^25.6.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^10.3.0",
        "eslint-config-next": "16.2.6",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-testing-library": "^7.16.1",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "knip": "^6.12.2",
        "lint-staged": "^17.0.4",
        "msw": "^2.14.5",
        "next-router-mock": "^1.0.5",
        "orval": "^8.9.1",
        "pino-pretty": "^13.1.3",
        "postcss": "^8.5.14",
        "prettier": "^3.8.3",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.11",
        "vitest": "^4.1.5"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,css,md}": "prettier --write",
        "*.{js,jsx,ts,tsx}": "eslint --no-warn-ignored --max-warnings=0 --fix"
    },
    "overrides": {
        "semver": "7.5.3",
        "optionator": "0.9.3",
        "react-day-picker": {
            "react": "^19.0.0"
        },
        "next-navigation-guard": {
